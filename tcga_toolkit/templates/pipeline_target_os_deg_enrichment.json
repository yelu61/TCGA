{
  "task": "pipeline",
  "task_id": "target-os-deg-enrichment-pipeline",
  "steps": [
    {
      "task": "run_deg",
      "task_id": "target-os-metas-vs-nonmetas",
      "project": "TARGET-OS",
      "group_column": "metastasis_at_diagnosis",
      "numerator": "Metastasis, NOS",
      "denominator": "No Metastasis",
      "padj_cutoff": 0.05,
      "min_count": 10,
      "min_fraction": 0.25
    },
    {
      "task": "run_enrichment",
      "task_id": "target-os-metas-enrichment",
      "mode": "ora",
      "input_deg": "{{step0.glob:*_deg.csv}}",
      "gmt_paths": [
        "1-Input/Homo-HALLMARK-gmts.txt",
        "1-Input/Homo-GOCC-gmts.txt",
        "1-Input/Homo-GOMF-gmts.txt"
      ],
      "padj_cutoff": 0.05,
      "log2fc_cutoff": 1
    }
  ]
}
